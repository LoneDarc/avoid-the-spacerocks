<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" style="background-color: rgba(255, 255, 255, 0.29); color: rgb(255, 255, 255); position: relative; top: 20px; align-self: center; width: auto; font-size: 25px; border-left-color: rgb(255, 255, 255); border-left-width: 3px; border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-bottom-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px;"/>
    <ui:Button text="Restart?" name="Restart_Btn" style="height: 49px; width: 242px; align-items: auto; align-self: center; top: 50%; color: rgb(255, 255, 255); background-color: rgba(255, 255, 255, 0.384); border-left-width: 3px; border-left-color: rgb(255, 255, 255); border-top-left-radius: 6px; border-top-width: 3px; border-top-right-radius: 6px; border-right-width: 3px; border-bottom-right-radius: 6px; border-bottom-width: 3px; border-bottom-left-radius: 6px; border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); font-size: 25px; position: absolute;"/>
    <ui:Button text="Menu" name="Menu_Btn" style="height: 49px; width: 242px; align-items: auto; align-self: center; top: 62%; color: rgb(255, 255, 255); background-color: rgba(255, 255, 255, 0.384); border-left-width: 3px; border-left-color: rgb(255, 255, 255); border-top-left-radius: 6px; border-top-width: 3px; border-top-right-radius: 6px; border-right-width: 3px; border-bottom-right-radius: 6px; border-bottom-width: 3px; border-bottom-left-radius: 6px; border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); font-size: 25px; position: absolute;"/>
    <ui:Label text="High Score: 0" name="HighScoreLabel" style="background-color: rgba(255, 255, 255, 0.29); color: rgb(255, 255, 255); position: relative; top: 20px; align-self: center; width: auto; font-size: 25px; border-left-color: rgb(255, 255, 255); border-left-width: 3px; border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-bottom-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px;"/>
</ui:UXML>
